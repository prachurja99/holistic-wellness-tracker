{
  "name": "holistic-wellness-tracker",
  "version": "1.0.0",
  "description": "A full-stack wellness application for habit tracking, mood monitoring, and journaling built with MERN stack following MVC architecture",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "npm-run-all --parallel server client",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client start",
    "install-server": "cd server && npm install",
    "install-client": "cd client && npm install",
    "install-all": "npm run install-server && npm run install-client"
  },
  "keywords": [
    "wellness",
    "habit-tracker",
    "mood-tracking",
    "journal",
    "MERN",
    "MVC"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "react-chartjs-2": "^5.3.0",
    "react-router-dom": "^7.7.0",
    "recharts": "^3.1.0"
  }
}
